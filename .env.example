# --- Core ---
MOCK_MODELS=true
STUDIO_ROOT=/app

# OpenAI (optional when MOCK_MODELS=true)
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small
OPENAI_VISION_MODEL=gpt-4o-mini

# Search (optional)
TAVILY_API_KEY=

# Storage
CHROMA_PERSIST_DIR=storage/chroma
UPLOAD_DIR=storage/uploads
EXTRACTED_IMAGES_DIR=storage/extracted_images

# MCP server (docker-compose sets host for the mcp service)
MCP_TRANSPORT=streamable-http
FASTMCP_HOST=0.0.0.0
FASTMCP_PORT=8765

# App → MCP (for external clients / future HTTP tool calls)
MCP_PUBLIC_URL=http://localhost:8765/mcp
